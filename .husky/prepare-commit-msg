#!/usr/bin/env bash

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"
SHA1="$3"

TEMPLATE_HEADER_LINE="# <type>[!][(<scope>)]: <summary> (<issue-ref>)"

# Run only for a plain interactive commit, where Git opens the editor.
if [[ -n "$COMMIT_SOURCE" || -n "$SHA1" ]]; then
  exit 0
fi

# Do nothing while rebase is in progress.
GIT_DIR="$(git rev-parse --git-dir 2>/dev/null || true)"
if [[ -n "$GIT_DIR" && ( -d "$GIT_DIR/rebase-merge" || -d "$GIT_DIR/rebase-apply" ) ]]; then
  exit 0
fi

has_template() {
  grep -qF "$TEMPLATE_HEADER_LINE" "$COMMIT_MSG_FILE"
}

BRANCH_NAME="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

HEADER=""

# Generate the header if branch name corresponds the regex.
if [[ "$BRANCH_NAME" =~ ^([^/]+)/([^/]+)/(.+)$ ]]; then
  TYPE="${BASH_REMATCH[1]}"
  ISSUE_REF="${BASH_REMATCH[2]}"

  HEADER="${TYPE}: <summary> (#${ISSUE_REF})"
fi

CONTENT="$(cat "$COMMIT_MSG_FILE")"

# Generate new content
{
  if [[ -n "$HEADER" ]]; then
    echo "$HEADER"
  fi

  echo "$CONTENT"

  # Add template if not already present
  if ! has_template; then
    echo ""
    echo "# Message template:"
    echo "$TEMPLATE_HEADER_LINE"
    echo "#"
    echo "# [optional body]"
    echo "#"
    echo "# [optional footer]"
  fi
} > "$COMMIT_MSG_FILE"
